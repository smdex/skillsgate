    "@skillsgate/ui": "*",
    "better-sqlite3": "12.8.0",
    "electron-updater": "6.6.2",
    "gray-matter": "4.0.3",
    "marked": "17.0.4",
    "react": "19.1.5",
    "react-dom": "19.1.5",
    "react-router-dom": "7.13.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.2.2",
