{
  "name": "skillsgate",
  "version": "1.0.0",
  "description": "Visual AI skill manager for all agents",
  "type": "module",
  "bin": {
    "skillsgate": "./bin/cli.mjs"
  },
  "files": [
    "bin",
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js"
    }
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "postinstall": "node bin/postinstall.mjs"
  },
  "keywords": [
    "ai",
    "agent",
    "skills",
    "tui",
    "visual",
    "manager",
    "claude",
    "cursor",
    "copilot"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/skillsgate/skillsgate",
    "directory": "packages/cli"
  },
  "dependencies": {
    "@napi-rs/keyring": "1.2.0",
    "gray-matter": "4.0.3",
    "simple-git": "3.32.3"
  },
  "devDependencies": {
    "@types/node": "22.19.11",
    "tsup": "8.5.1",
    "typescript": "5.9.3"
  }
}
