{
  "name": "skillsgate",
  "version": "0.2.2",
  "description": "Install and manage AI agent skills from GitHub",
  "type": "module",
  "bin": {
    "skillsgate": "./bin/cli.mjs"
  },
  "files": [
    "bin",
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js"
    },
    "./mcp": {
      "types": "./dist/mcp/server.d.ts",
      "import": "./dist/mcp/server.js"
    }
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "postinstall": "node bin/postinstall.mjs"
  },
  "keywords": [
    "ai",
    "agent",
    "skills",
    "claude",
    "cursor",
    "copilot",
    "cli"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/skillsgate/skillsgate",
    "directory": "packages/cli"
  },
  "dependencies": {
    "@clack/prompts": "0.10.1",
    "@modelcontextprotocol/sdk": "1.27.1",
    "@napi-rs/keyring": "1.2.0",
    "gray-matter": "4.0.3",
    "open": "11.0.0",
    "picocolors": "1.1.1",
    "simple-git": "3.32.3",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "22.19.11",
    "tsup": "8.5.1",
    "typescript": "5.9.3"
  }
}
