# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Dependencies
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Testing
coverage/

# Production
build/
dist/

# Misc
.DS_Store
*.pem

# Debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Environment files (can opt-in for committing if needed)
.env*
!.env.example

# Vercel
.vercel

# TypeScript
*.tsbuildinfo

# Prisma generated client
**/generated/prisma/

# ==========================================
# Root level specific
# ==========================================

# Root node_modules
/node_modules/

# Root .next (when dev is run from root)
/.next/
/.wrangler/

# ==========================================
# Apps/web specific (will also be in apps/web/.gitignore)
# ==========================================

# Next.js
apps/web/.next/
apps/web/out/
apps/web/build/

# OpenNext
apps/web/.open-next/

# Wrangler files
apps/web/.wrangler/
apps/web/.dev.vars*
!apps/web/.dev.vars.example

# Next.js specific
apps/web/next-env.d.ts
apps/web/*.tsbuildinfo

# ==========================================
# Packages/cli specific
# ==========================================

# Lock file written by skillsgate CLI
.skill-lock.json

